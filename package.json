  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.build.json && node scripts/prepare-dist.mjs",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs test/primitives/*.test.mjs",
    "pack:check": "npm_config_cache=/tmp/atom-ui-npm-cache npm pack --dry-run",
    "playground:dev": "npm --prefix playground run dev",
    "playground:build": "npm --prefix playground run build",
    "playground:preview": "npm --prefix playground run preview",
    "release:check": "npm run test && npm run build && npm run pack:check",
    "prepublishOnly": "npm run build"
  },
